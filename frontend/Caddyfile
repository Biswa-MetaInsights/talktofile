# DOMAIN drives automatic HTTPS. For a real domain Caddy obtains a Let's Encrypt
# certificate automatically (ports 80/443 must be reachable). Defaults to
# "localhost" for local testing, where Caddy uses its internal CA.
{$DOMAIN:localhost} {
	encode zstd gzip

	# API + WebSockets → backend container. Caddy upgrades ws/wss automatically.
	handle /api/* {
		reverse_proxy backend:9099
	}

	# SEO blog (a static Astro build) → served from /srv/blog. The blog is built
	# with base:/blog, so its URLs keep the /blog prefix and the files live under
	# /srv/blog. This block is BEFORE the SPA catch-all so /blog/* never falls
	# through to the React app's index.html.
	handle /blog* {
		root * /srv

		# Astro's hashed assets never change once built — cache them forever.
		@blogAssets path /blog/_astro/*
		header @blogAssets Cache-Control "public, max-age=31536000, immutable"

		# Blog HTML must revalidate so new posts appear immediately on deploy.
		@blogHtml not path /blog/_astro/*
		header @blogHtml Cache-Control "no-cache"

		try_files {path} {path}/index.html
		file_server
	}

	# Single-page app: serve files, fall back to index.html for client routes.
	handle {
		root * /srv

		# Vite's build assets are content-hashed (their filename changes whenever
		# the contents change), so they're safe to cache "forever".
		@assets path /assets/*
		header @assets Cache-Control "public, max-age=31536000, immutable"

		# The SPA shell (index.html and any non-asset path) must always be
		# revalidated, so a new deploy is picked up immediately — no cache purge.
		@shell not path /assets/*
		header @shell Cache-Control "no-cache"

		try_files {path} /index.html
		file_server
	}

	# Sensible security headers.
	header {
		Strict-Transport-Security "max-age=31536000; includeSubDomains"
		X-Content-Type-Options "nosniff"
		X-Frame-Options "DENY"
		Referrer-Policy "strict-origin-when-cross-origin"
		-Server
	}
}

# Redirect the www subdomain to the canonical apex domain (one URL, no
# duplicate-content or cookie/CORS mismatch). Caddy fetches a cert for www too,
# so both hostnames must have DNS pointing at this box. Harmless locally
# (www.localhost via Caddy's internal CA).
www.{$DOMAIN:localhost} {
	redir https://{$DOMAIN:localhost}{uri} permanent
}
